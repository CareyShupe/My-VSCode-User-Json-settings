{
  // ============================================================
  //  THEME & ICONS
  // ============================================================
  "workbench.colorTheme": "Night Owl",
  "workbench.iconTheme": "material-icon-theme",
  "material-icon-theme.hidesExplorerArrows": true,
  // ============================================================
  //  WORKBENCH LAYOUT
  // ============================================================
  "workbench.sideBar.location": "right",
  "workbench.tree.indent": 15,
  "workbench.tree.renderIndentGuides": "always",
  "workbench.editor.showTabs": "multiple",
  "workbench.editor.tabSizing": "shrink",
  "workbench.editor.enablePreview": false,
  "workbench.editor.autoLockGroups": {
    "jupyter-notebook": true
  },
  "workbench.editor.preferHistoryBasedLanguageDetection": true,
  "workbench.layoutControl.enabled": false,
  "workbench.startupEditor": "newUntitledFile",
  "workbench.panel.opensMaximized": "never",
  "workbench.tips.enabled": false,
  "workbench.secondarySideBar.defaultVisibility": "hidden",
  "workbench.editorAssociations": {
    "*.ps1": "default"
  },
  "workbench.settings.applyToAllProfiles": [
    "workbench.colorCustomizations",
    "editor.tokenColorCustomizations",
    "editor.semanticTokenColorCustomizations",
    "workbench.startupEditor"
  ],
  // ============================================================
  //  WINDOW
  // ============================================================
  "window.restoreWindows": "none",
  "window.density.editorTabHeight": "compact",
  "window.newWindowDimensions": "maximized",
  "window.openFoldersInNewWindow": "off",
  "window.openWithoutArgumentsInNewWindow": "off",
  "window.commandCenter": false,
  "window.titleSeparator": " | ",
  "window.title": "${dirty}${remoteName}${separator}${rootName}${separator}${activeEditorShort}${separator}${appName}",
  // ============================================================
  //  COLOR CUSTOMIZATIONS
  // ============================================================
  "workbench.colorCustomizations": {
    // --- Sidebar & Explorer ---
    "sideBar.background": "#271638",
    "tree.indentGuidesStroke": "#05ef3c",
    "list.activeSelectionBackground": "#271a41",
    "list.inactiveSelectionBackground": "#271a41",
    "list.focusBackground": "#271a41",
    "list.hoverBackground": "#271a41",
    // --- Editor ---
    "editor.lineHighlightBackground": "#202640",
    "editor.lineHighlightBorder": "#9fced11f",
    "editorLineNumber.activeForeground": "#ffff00",
    "editorSuggestWidget.selectedBackground": "#271a41",
    // --- Bracket Pair Colors ---
    "editorBracketHighlight.foreground1": "#569CD6",
    "editorBracketHighlight.foreground2": "#C586C0",
    "editorBracketHighlight.foreground3": "#4EC9B0",
    "editorBracketHighlight.foreground4": "#CE9178",
    // --- ErrorLens ---
    "errorLens.errorBackground": "#e4545410",
    "errorLens.errorForeground": "#ff646440",
    "errorLens.errorMessageBackground": "#e4545405",
    "errorLens.infoBackground": "#2472c810",
    "errorLens.infoForeground": "#2472c8B0",
    "errorLens.warningBackground": "#ff942f10",
    "errorLens.warningForeground": "#fa973a70",
    "errorLens.warningMessageBackground": "#fff00005",
    // --- Terminal ---
    "terminal.background": "#3b353500",
    "terminal.foreground": "#D4D4D4",
    "terminalCursor.foreground": "#569cd6",
    "terminal.ansiBlack": "#000000",
    "terminal.ansiBlue": "#2472c8",
    "terminal.ansiBrightBlack": "#666666",
    "terminal.ansiBrightBlue": "#569cd6",
    "terminal.ansiBrightCyan": "#9cdcfe",
    "terminal.ansiBrightGreen": "#b5cea8",
    "terminal.ansiBrightRed": "#f14c4c",
    "terminal.ansiBrightYellow": "#DCDCAA",
    "terminal.ansiCyan": "#11a8cd",
    "terminal.ansiGreen": "#6a9955",
    "terminal.ansiMagenta": "#C586C0",
    "terminal.ansiRed": "#cd3131",
    "terminal.ansiYellow": "#CE9178"
  },
  // ============================================================
  //  TOKEN COLOR CUSTOMIZATIONS (Comment Styling)
  // ============================================================
  "editor.tokenColorCustomizations": {
    "textMateRules": [
      {
        "scope": [
          "comment",
          "comment.block.documentation",
          "comment.line.double-slash",
          "comment.line.number-sign",
          "comment.block.documentation.string"
        ],
        "settings": {
          "foreground": "#00FF00",
          "fontStyle": "italic bold"
        }
      }
    ]
  },
  // ============================================================
  //  SEMANTIC TOKEN COLOR CUSTOMIZATIONS
  // ============================================================
  "editor.semanticTokenColorCustomizations": {
    "enabled": true,
    "rules": {
      "punctuation.section.bracket.end.powershell": "#569CD6",
      "*.variable": {
        "foreground": "#ffcc00"
      },
      "*.function": {
        "foreground": "#00ffcc",
        "bold": true
      },
      "*.keyword": {
        "foreground": "#ff6699",
        "italic": true
      }
    }
  },
  // ============================================================
  //  EDITOR — APPEARANCE
  // ============================================================
  "editor.fontFamily": "'CaskaydiaCove NF', monospace",
  "editor.fontLigatures": true,
  "editor.fontSize": 14,
  "editor.fontWeight": "400",
  "editor.letterSpacing": -0.1,
  "editor.lineHeight": 1.5,
  "editor.minimap.enabled": false,
  "editor.minimap.renderCharacters": false,
  "editor.renderWhitespace": "all",
  "editor.renderControlCharacters": true,
  // NOTE: "all" enables line highlight — color controlled by colorCustomizations above
  "editor.renderLineHighlight": "all",
  "editor.rulers": [
    {
      "column": 120,
      "color": "#1f3a4066"
    }
  ],
  "editor.overviewRulerBorder": false,
  "editor.scrollbar.vertical": "visible",
  "editor.scrollbar.horizontal": "visible",
  "editor.scrollbar.verticalScrollbarSize": 15,
  "editor.scrollbar.horizontalScrollbarSize": 15,
  "editor.lightbulb.enabled": "off",
  // ============================================================
  //  EDITOR — CURSOR & SCROLLING
  // ============================================================
  "editor.cursorBlinking": "expand",
  "editor.cursorSmoothCaretAnimation": "on",
  "editor.cursorSurroundingLines": 3,
  "editor.cursorSurroundingLinesStyle": "all",
  "editor.smoothScrolling": true,
  "editor.mouseWheelZoom": true,
  // ============================================================
  //  EDITOR — BRACKET & INDENTATION GUIDES
  // ============================================================
  "editor.bracketPairColorization.enabled": true,
  "editor.bracketPairColorization.independentColorPoolPerBracketType": true,
  "editor.guides.bracketPairs": "active",
  "editor.guides.bracketPairsHorizontal": true,
  "editor.guides.highlightActiveBracketPair": true,
  "editor.guides.indentation": true,
  "editor.guides.highlightActiveIndentation": true,
  "editor.matchBrackets": "near",
  "editor.language.brackets": [
    [
      "{",
      "}"
    ],
    [
      "(",
      ")"
    ],
    [
      "#region",
      "#endregion"
    ]
  ],
  // ============================================================
  //  EDITOR — INTELLISENSE & SUGGESTIONS
  // ============================================================
  "editor.hover.enabled": true,
  "editor.parameterHints.enabled": true,
  "editor.quickSuggestions": {
    "comments": "on",
    "strings": "on",
    "other": "off"
  },
  "editor.suggestSelection": "first",
  "editor.suggest.preview": false,
  "editor.suggest.localityBonus": true,
  "editor.suggest.showStatusBar": true,
  "editor.suggest.showIcons": true,
  "editor.suggest.showClasses": false,
  "editor.suggest.showConstants": false,
  "editor.suggest.showConstructors": false,
  "editor.suggest.showEnumMembers": false,
  "editor.suggest.showEnums": false,
  "editor.suggest.showEvents": false,
  "editor.suggest.showFields": false,
  "editor.suggest.snippetsPreventQuickSuggestions": false,
  "editor.snippetSuggestions": "bottom",
  "editor.wordBasedSuggestions": "currentDocument",
  "editor.tabCompletion": "on",
  "editor.inlayHints.enabled": "offUnlessPressed",
  "editor.inlayHints.fontSize": 12,
  // Inline suggestions (Copilot ghost text) — enabled; see Copilot section
  "editor.inlineSuggest.enabled": true,
  "editor.inlineSuggest.showToolbar": "always",
  "editor.inlineSuggest.syntaxHighlightingEnabled": true,
  // ============================================================
  //  EDITOR — BEHAVIOR
  // ============================================================
  "editor.accessibilitySupport": "on",
  "editor.autoClosingBrackets": "languageDefined",
  "editor.autoClosingQuotes": "languageDefined",
  "editor.autoIndent": "full",
  "editor.autoSurround": "brackets",
  "editor.codeActions.triggerOnFocusChange": true,
  "editor.columnSelection": false,
  "editor.dragAndDrop": true,
  "editor.find.cursorMoveOnType": false,
  "editor.linkedEditing": true,
  "editor.semanticHighlighting.enabled": true,
  "editor.showFoldingControls": "always",
  "editor.stickyTabStops": true,
  "editor.unicodeHighlight.nonBasicASCII": false,
  "editor.unicodeHighlight.invisibleCharacters": false,
  "editor.unicodeHighlight.ambiguousCharacters": false,
  "editor.unicodeHighlight.allowedCharacters": {
    "\u00a0": true
  },
  "editor.wordWrap": "on",
  "editor.wordWrapColumn": 120,
  "editor.wrappingIndent": "same",
  // ============================================================
  //  EDITOR — FORMATTING
  // ============================================================
  // NOTE: defaultFormatter is intentionally NOT set globally.
  //       It is scoped per-language below to avoid conflicts.
  "editor.formatOnPaste": true,
  "editor.formatOnSave": true,
  "editor.formatOnType": true,
  "editor.codeActionsOnSave": {
    "source.organizeImports": "always",
    "source.fixAll": "always"
  },
  "editor.detectIndentation": false,
  "editor.foldingImportsByDefault": true,
  "editor.insertSpaces": true,
  "editor.tabSize": 4,
  "editor.useTabStops": true,
  // ============================================================
  //  LANGUAGE-SPECIFIC OVERRIDES
  // ============================================================
  "[powershell]": {
    "editor.defaultFormatter": "ms-vscode.powershell",
    "editor.tabSize": 4,
    "editor.wordWrapColumn": 120
  },
  "[json]": {
    "editor.defaultFormatter": "vscode.json-language-features",
    "editor.tabSize": 2
  },
  "[jsonc]": {
    "editor.defaultFormatter": "vscode.json-language-features",
    "editor.tabSize": 2
  },
  "[yaml]": {
    "editor.tabSize": 2,
    "editor.insertSpaces": true
  },
  "[markdown]": {
    "editor.wordWrap": "on",
    "editor.quickSuggestions": {
      "comments": "off",
      "strings": "off",
      "other": "off"
    }
  },
  // ============================================================
  //  FILES
  // ============================================================
  "files.defaultLanguage": "powershell",
  "files.autoSave": "onFocusChange",
  "files.autoSaveDelay": 10000,
  "files.hotExit": "onExitAndWindowClose",
  "files.trimFinalNewlines": true,
  "files.trimTrailingWhitespace": true,
  // ============================================================
  //  EXPLORER
  // ============================================================
  "explorer.confirmDelete": false,
  "explorer.confirmDragAndDrop": false,
  "explorer.fileNesting.enabled": true,
  // ============================================================
  //  EXTENSIONS
  // ============================================================
  "extensions.autoUpdate": true,
  "extensions.autoCheckUpdates": true,
  "extensions.ignoreRecommendations": true,
  // ============================================================
  //  POWERSHELL EXTENSION
  // ============================================================
  "powershell.promptToUpdatePowerShell": false,
  "powershell.startAutomatically": true,
  "powershell.scriptAnalysis.enable": true,
  "powershell.integratedConsole.showOnStartup": false,
  "powershell.pester.codeLens": false,
  "powershell.powerShellAdditionalExePaths": {
    "pwsh7": "C:\\Program Files\\PowerShell\\7\\pwsh.exe"
  },
  "powershell.codeFormatting.preset": "Allman",
  "powershell.codeFormatting.addWhitespaceAroundPipe": true,
  "powershell.codeFormatting.alignPropertyValuePairs": true,
  "powershell.codeFormatting.autoCorrectAliases": true,
  "powershell.codeFormatting.avoidSemicolonsAsLineTerminators": true,
  "powershell.codeFormatting.ignoreOneLineBlock": false,
  "powershell.codeFormatting.newLineAfterCloseBrace": true,
  "powershell.codeFormatting.newLineAfterOpenBrace": true,
  "powershell.codeFormatting.openBraceOnSameLine": false,
  "powershell.codeFormatting.pipelineIndentationStyle": "IncreaseIndentationForFirstPipeline",
  "powershell.codeFormatting.trimWhitespaceAroundPipe": true,
  "powershell.codeFormatting.useCorrectCasing": true,
  "powershell.codeFormatting.whitespaceAfterSeparator": true,
  "powershell.codeFormatting.whitespaceAroundOperator": true,
  "powershell.codeFormatting.whitespaceBeforeOpenBrace": true,
  "powershell.codeFormatting.whitespaceBeforeOpenParen": true,
  "powershell.codeFormatting.whitespaceBetweenParameters": false,
  "powershell.codeFormatting.whitespaceInsideBrace": true,
  // ============================================================
  //  TERMINAL
  // ============================================================
  "terminal.integrated.defaultProfile.windows": "PowerShell",
  "terminal.integrated.profiles.windows": {
    "PowerShell": {
      "path": "pwsh.exe",
      "icon": "terminal-powershell"
    },
    "Command Prompt": {
      "path": [
        "${env:windir}\\Sysnative\\cmd.exe",
        "${env:windir}\\System32\\cmd.exe"
      ],
      "args": [],
      "icon": "terminal-cmd"
    },
    "Git Bash": {
      "source": "Git Bash",
      "icon": "terminal-git-bash"
    }
  },
  "terminal.integrated.automationProfile.windows": {
    "path": "pwsh.exe"
  },
  "terminal.external.windowsExec": "pwsh.exe",
  "terminal.explorerKind": "external",
  "terminal.integrated.fontFamily": "Cascadia Code PL, monospace",
  "terminal.integrated.fontSize": 14,
  "terminal.integrated.fontWeight": "normal",
  "terminal.integrated.fontWeightBold": "bold",
  "terminal.integrated.cursorStyle": "line",
  "terminal.integrated.cursorBlinking": true,
  "terminal.integrated.cursorWidth": 1,
  "terminal.integrated.hideOnStartup": "always",
  "terminal.integrated.confirmOnExit": "never",
  "terminal.integrated.enablePersistentSessions": false,
  "terminal.integrated.persistentSessionReviveProcess": "never",
  "terminal.integrated.tabs.showActiveTerminal": "never",
  "terminal.integrated.mouseWheelZoom": true,
  "terminal.integrated.scrollback": 1000,
  "terminal.integrated.minimumContrastRatio": 1,
  "terminal.integrated.suggest.enabled": true,
  "terminal.integrated.enableImages": true,
  "terminal.integrated.gpuAcceleration": "auto",
  // ============================================================
  //  GIT
  // ============================================================
  "git.openRepositoryInParentFolders": "always",
  "git.enableSmartCommit": true,
  "git.confirmSync": false,
  "git.autofetch": true,
  "git.blame.editorDecoration.enabled": true,
  "git-graph.repository.fetchAndPruneTags": true,
  "git-autoconfig.configList": [
    {
      "user.email": "cwshupe@gmail.com",
      "user.name": "Carey Shupe"
    }
  ],
  // ============================================================
  //  GITLENS
  // ============================================================
  "gitlens.ai.model": "vscode",
  "gitlens.ai.vscode.model": "copilot:gpt-4.1",
  // ============================================================
  //  COPILOT / AI
  // ============================================================
  // Best practice: keep inline suggestions active (high value, low noise).
  // Chat UI and agent features are disabled — re-enable if you start using them.
  // "editor.inlineSuggest.enabled" is set above in the Editor section.
  "chat.agent.enabled": false,
  "chat.agentsControl.enabled": false,
  "chat.mcp.autostart": "never",
  "chat.mcp.access": "none",
  "chat.mcp.apps.enabled": false,
  "chat.extensionUnification.enabled": false,
  "chat.extensionTools.enabled": false,
  "chat.detectParticipant.enabled": false,
  "chat.implicitContext.suggestedContext": false,
  "inlineChat.affordance": "off",
  // ============================================================
  //  DEBUG
  // ============================================================
  "debug.console.fontFamily": "default",
  "debug.breakpointsView.presentation": "tree",
  // ============================================================
  //  SECURITY
  // ============================================================
  "security.workspace.trust.banner": "always",
  "security.workspace.trust.untrustedFiles": "open",
  // ============================================================
  //  JSON SCHEMAS
  // ============================================================
  "json.schemas": [
    {
      "fileMatch": [
        "markdownlint.json",
        ".markdownlint.json"
      ],
      "url": "https://raw.githubusercontent.com/DavidAnson/markdownlint/v0.40.0/schema/markdownlint-config-schema.json"
    }
  ]
}